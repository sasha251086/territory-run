{
  "name": "web",
  "private": true,
  "version": "2.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "preview": "vite preview",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios",
    "mobile:setup": "node ./scripts/setup-android.mjs",
    "mobile:sync": "node ./scripts/sync-android-shell.mjs && node ./scripts/patch-capacitor-settings.mjs && node ./scripts/ensure-android-resources.mjs && node ./scripts/ensure-android-sources.mjs && node ./scripts/ensure-samsung-sdk.mjs",
    "mobile:apk": "powershell -ExecutionPolicy Bypass -File ./scripts/install-android-apk.ps1",
    "mobile:build": "node ./scripts/mobile-build.mjs",
    "mobile:bundle": "node ./scripts/bundle-web-for-android.mjs",
    "mobile:build:offline": "node ./scripts/mobile-build-offline.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "capacitor-health": "^8.1.2",
    "h3-js": "4.4.0",
    "leaflet": "^1.9.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@types/leaflet": "^1.9.20",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.0.1"
  }
}
