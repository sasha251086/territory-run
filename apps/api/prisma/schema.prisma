generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  nickname     String   @unique
  passwordHash String
  avatarUrl    String?
  homeLat      Float?
  homeLng      Float?
  freezeActive       Boolean   @default(false)
  freezeActivatedAt  DateTime?
  freezeLastUsedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activities   Activity[]
  ownerships   CellOwnership[]
  stats        UserStats?
  events       Event[]
  ruledDistricts District[] @relation("DistrictKing")
  integrations Integration[]
  rivalsFollowing RivalFollow[] @relation("RivalFollower")
  rivalsFollowers RivalFollow[] @relation("RivalTarget")
  seasonResults SeasonResult[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model District {
  id         String   @id @default(uuid())
  name       String
  polygon    Json
  kingUserId String?
  createdAt  DateTime @default(now())

  kingUser   User?          @relation("DistrictKing", fields: [kingUserId], references: [id], onDelete: SetNull)
  cells      DistrictCell[]
}

model DistrictCell {
  districtId String
  h3Index    String

  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  cell       Cell     @relation(fields: [h3Index], references: [h3Index], onDelete: Cascade)

  @@id([districtId, h3Index])
  @@index([h3Index])
}

model Activity {
  id              String         @id @default(uuid())
  userId          String
  source          String
  distanceMeters  Int
  durationSeconds Int
  avgPace         Int?
  startedAt       DateTime
  finishedAt      DateTime
  processedAt     DateTime?
  status          ActivityStatus @default(processing)
  failureReason   String?
  createdAt       DateTime       @default(now())

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  track           ActivityTrack?
}

model ActivityTrack {
  activityId  String   @id
  route       Json
  createdAt   DateTime @default(now())

  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model Cell {
  h3Index     String   @id
  center      Json?     // можно хранить { lat, lng }
  centerLat   Float?
  centerLng   Float?
  createdAt   DateTime @default(now())

  ownerships  CellOwnership[]
  districtCells DistrictCell[]
  history     CellHistory[]

  @@index([centerLat, centerLng])
}

model CellOwnership {
  h3Index        String
  userId         String
  influence      Float    @default(0)
  lastActivityAt DateTime @default(now())

  cell   Cell @relation(fields: [h3Index], references: [h3Index], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([h3Index, userId])
  @@index([userId])
  @@index([h3Index])
}
model UserStats {
  userId         String   @id
  totalDistance  BigInt   @default(0)
  totalRuns      Int      @default(0)
  cellsOwned     Int      @default(0)
  totalInfluence Float    @default(0)
  currentStreak  Int      @default(0)
  lastRunDate    DateTime?
  firstCaptureShownAt DateTime?
  seasonCellsOwned    Int      @default(0)
  seasonInfluence     Float    @default(0)
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RivalFollow {
  followerId   String
  targetUserId String
  createdAt    DateTime @default(now())

  follower User @relation("RivalFollower", fields: [followerId], references: [id], onDelete: Cascade)
  target   User @relation("RivalTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@id([followerId, targetUserId])
  @@index([followerId])
}

model CellHistory {
  id         String   @id @default(uuid())
  h3Index    String
  fromUserId String?
  toUserId   String
  changedAt  DateTime @default(now())

  cell Cell @relation(fields: [h3Index], references: [h3Index], onDelete: Cascade)

  @@index([h3Index, changedAt(sort: Desc)])
}
model Event {
  id        String   @id @default(uuid())
  type      String
  userId    String
  payload   Json
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Season {
  id        Int      @id @default(autoincrement())
  number    Int      @unique
  startDate DateTime
  endDate   DateTime
  status    String   @default("active")
  results   SeasonResult[]
}

model SeasonResult {
  id             Int    @id @default(autoincrement())
  seasonId       Int
  userId         String
  rank           Int
  cellsOwned     Int
  totalInfluence Float
  season         Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@index([userId])
}

enum ActivityStatus {
  processing
  completed
  failed
}

model Integration {
  id             String   @id @default(uuid())
  userId         String
  provider       String
  externalUserId String?
  accessToken    String
  refreshToken   String
  expiresAt      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model ProcessedActivity {
  provider           String
  externalActivityId String

  @@id([provider, externalActivityId])
}