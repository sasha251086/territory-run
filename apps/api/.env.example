# Пример переменных окружения для разработки
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/territory_run?schema=public"
# Для seed с ПК на Render Postgres — External Database URL (с доменом *.render.com), не Internal.
JWT_SECRET=your_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
# Access token TTL (e.g. 7d, 24h). Refresh token is stored for JWT_REFRESH_EXPIRES_DAYS.
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_DAYS=90
# Comma-separated list of allowed frontend origins (production)
ALLOWED_ORIGINS=http://localhost:5173
# 32+ character secret for encrypting OAuth tokens in the database
TOKEN_ENCRYPTION_KEY=change_me_to_a_long_random_secret_key
NODE_ENV=development
PORT=3000
REDIS_HOST=localhost
REDIS_PORT=6379

# Sentry (опционально — ошибки 500 и сбои очереди)
SENTRY_DSN=

# Strava OAuth (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/integrations/strava/callback
